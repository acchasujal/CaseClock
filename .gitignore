# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.eggs/
.env
.venv
venv/
env/
pip-wheel-metadata/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Node / Frontend
node_modules/
**/node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
*.log
npm-debug.log*

# Environment files — never commit real credentials
.env
.env.local
.env.*.local
*.env

# Catalyst credentials and deploy artifacts
deployment/*.key
deployment/*.pem
catalyst.json.bak
.zcatalyst/
.catalystrc.bak
frontend/.catalyst/

# Vendored Python packages (pip install -t .) — never commit these
# AppSail installs dependencies from requirements.txt at build time
backend/*.dist-info/
backend/typing_extensions.py
backend/py.py
backend/bin/
backend/_pytest/
backend/annotated_doc/
backend/annotated_types/
backend/anyio/
backend/certifi/
backend/charset_normalizer/
backend/click/
backend/colorama/
backend/dotenv/
backend/fastapi/
backend/h11/
backend/httpcore/
backend/httpx/
backend/idna/
backend/iniconfig/
backend/networkx/
backend/packaging/
backend/pluggy/
backend/pydantic/
backend/pydantic_core/
backend/pydantic_settings/
backend/pygments/
backend/pytest/
backend/requests/
backend/ruff/
backend/starlette/
backend/typing_inspection/
backend/urllib3/
backend/uvicorn/

# backend/shared/ is a deployment-only copy of root shared/
# It is synced before each AppSail deploy, not tracked in git
backend/shared/

# IDE
.idea/
.vscode/settings.json
*.swp
*.swo
.DS_Store
Thumbs.db

# Test artifacts
tests/scale/results/*.json
ai/tests/refusal_testset/results/*.json
artifacts/runtime_state/
