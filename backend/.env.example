# CaseClock Backend — Environment Variables
#
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env to git.
# Production values are configured via Catalyst AppSail environment variables.

# ── Service identity ────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Development: local Vite dev server.
# Production: set to the deployed Catalyst Slate URL in AppSail.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Repository backend ──────────────────────────────────────────────────────
# Options: local (in-memory JSON) | catalyst (Zoho Catalyst Data Store)
CASECLOCK_REPOSITORY=local

# ── Data paths (in-memory / local repository) ──────────────────────────────
# Path to the synthetic graph JSON artifact (relative to backend/ directory).
# Leave as default for standard repo layout.
# ARTIFACT_PATH=artifacts/synthetic_graph/synthetic_graph.json

# Path for mutable runtime state (dependency updates, escalations).
# Leave empty to disable persistence across restarts.
# STATE_PATH=

# ── Catalyst integration (Phase 2/3 — leave empty in development) ──────────
# CATALYST_PROJECT_ID=
# CATALYST_CLIENT_ID=
