# Replace @lane1-owner, @lane2-owner, @lane3-owner with actual GitHub usernames.

# Global fallback — Lane 4 reviews anything unclaimed
*                           @acchasujal

# Lane 1 — Backend Core (clock, dependency, escalation, auth, API)
/backend/                   @lane1-owner
/shared/constants/          @lane1-owner @acchasujal

# Lane 2 — Frontend (all React screens and components)
/frontend/                  @lane2-owner
